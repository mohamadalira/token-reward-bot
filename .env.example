# Telegram
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321
WEBAPP_URL=http://YOUR_SERVER_IP:8080

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tokenbot
POSTGRES_USER=tokenbot
POSTGRES_PASSWORD=change_me_strong_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_me_api_secret_key_min_32_chars
WEBHOOK_PATH=/webhook/plisio
WEBHOOK_URL=http://YOUR_SERVER_IP:8080/webhook/plisio

# Plisio — فقط API Token از پنل Plisio کافیه
PLISIO_API_KEY=your_plisio_api_token
PLISIO_SECRET_KEY=
PLISIO_ENABLED=true

# Domain & SSL (optional — leave DOMAIN empty for IP-only install)
DOMAIN=
SSL_EMAIL=
SSL_ENABLED=false
TOKENBOT_HTTP_PORT=8080
TOKENBOT_HTTPS_PORT=8443
SERVER_IP=

# App
DEBUG=false
LOG_LEVEL=INFO
DEFAULT_LOCALE=fa
USE_PERSIAN_NUMBERS=true
USE_JALALI_DATES=true
